# Groq chat + Whisper-class STT (optional overrides)
VITE_GROQ_CHAT_MODEL=llama-3.1-8b-instant
VITE_GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo

# Used ONLY on the server: Vite dev proxy and Vercel api/groq routes — never bundle into client JS.
# Copy to `.env` and set your key from https://console.groq.com/
# (Optional fallback for the same proxy code: OPENAI_API_KEY=)
GROQ_API_KEY=
