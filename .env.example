# Provider: omit or 0 = OpenAI; 1 = Groq (free tier, OpenAI-compatible — good for hackathons)
VITE_USE_GROQ=true

# OpenAI models (when VITE_USE_GROQ=0)
VITE_OPENAI_CHAT_MODEL=gpt-4o-mini
VITE_OPENAI_TRANSCRIPTION_MODEL=whisper-1

# Groq models (when VITE_USE_GROQ=1)
VITE_GROQ_CHAT_MODEL=llama-3.1-8b-instant
VITE_GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo

# Used ONLY by the Vite dev server proxies — never bundled into client JS.
# Copy to `.env` and fill in (never commit real keys).
OPENAI_API_KEY=
GROQ_API_KEY=
