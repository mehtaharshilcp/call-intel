# Groq chat + Whisper-class STT (optional overrides)
VITE_GROQ_CHAT_MODEL=llama-3.1-8b-instant
VITE_GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo

# Used ONLY on the server: Vite dev proxy and Vercel api/* routes — never bundle into client JS.
GROQ_API_KEY=

# Vercel only: Storage → Blob (required for audio >~2MB, up to 15MB; avoids FUNCTION_PAYLOAD_TOO_LARGE)
# BLOB_READ_WRITE_TOKEN=
