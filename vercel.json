{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/groq/openai/v1/audio/transcriptions.ts": {
      "maxDuration": 120
    },
    "api/groq/openai/v1/chat/completions.ts": {
      "maxDuration": 60
    },
    "api/blob/upload.ts": {
      "maxDuration": 60
    }
  }
}
